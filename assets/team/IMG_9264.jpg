<script>
window.addEventListener('load', function() {
  setTimeout(function() {
    document.getElementById('kspop').style.display = 'flex';
  }, 1000); // Delay in milliseconds

  // allows user to close the floating bar
  document.getElementById('close').addEventListener('click', function() {
    document.getElementById('kspop').style.display = 'none';
  });

  // hides the floating bar and show the form modal
    document.getElementById('textus').addEventListener('click', function() {
    document.getElementById('ksform').style.display = 'flex';
    document.getElementById('kspop').style.display = 'none';
  });

  // hides the form
  document.getElementById('form-close').addEventListener('click', function() {
    document.getElementById('ksform').style.display = 'none';
  });

});
