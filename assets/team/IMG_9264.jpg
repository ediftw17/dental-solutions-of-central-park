/*===== ...Image Grid =====*/

/*===== Image Grid =====*/
#image-grid-title {
    font-size: 35px;
    font-weight: bold !important;
    color: #4bac25 !important;
    padding: 40px 0 20px 0;
    margin-bottom: 0;
    text-align: center;
}

.image-grid {
    display: grid;
/*     grid-template-columns: repeat(3, 1fr);
    grid-template-rows: repeat(3, 1fr); */
    margin: 0 auto 50px auto;
    gap: 10px;
    padding: 50px 0;
}

.image-grid div img {
    width: 100%;
    height: 100%;
    max-height: 650px;
    object-fit: cover;
}

.box-1 {
    background-color: tan;
    grid-column: 1 / 2;
    grid-row: 1 / 3;
}

.box-2 {
    background-color: tan;
    grid-column: 2 / 3;
    grid-row: 1 / 2;
}

.box-3 {
    background-color: tan;
    grid-column: 3 / 4;
    grid-row: 1 / 2;
}

.box-4 {
    background-color: tan;
    grid-column: 1 / 2;
    grid-row: 3 / 4;
}

.box-5 {
    background-color: tan;
    grid-column: 2 / 3;
    grid-row: 2 / 4;
}

.box-6 {
    background-color: tan;
    grid-column: 3 / 4;
    grid-row: 2 / 3;
}

.box-7 {
    background-color: tan;
    grid-column: 3 / 4;
    grid-row: 3 / 4;
}

@media (max-width: 1300px) {
    .box-1 {
        grid-column: 1 / 3;
        grid-row: 1 / 2;
    }

    .box-2 {
        grid-column: 3 / 4;
        grid-row: 1 / 2;
    }

    .box-3 {
        grid-column: 1 / 2;
        grid-row: 2 / 3;
    }

    .box-4 {
        grid-column: 2 / 4;
        grid-row: 2 / 3;
    }

    .box-5 {
        grid-column: 1 / 3;
        grid-row: 3 / 4;
    }

    .box-6 {
        grid-column: 3 / 4;
        grid-row: 3 / 4;
    }

    .box-7 {
        grid-column: 1 / 4;
        grid-row: 4 / 5;
    }
}

@media (max-width: 850px) {
    .box-1 {
        grid-column: 1 / 4;
        grid-row: 1 / 2;
    }

    .box-2 {
        grid-column: 1 / 4;
        grid-row: 2 / 3;
    }

    .box-3 {
        grid-column: 1 / 4;
        grid-row: 3 / 4;
    }

    .box-4 {
        grid-column: 1 / 4;
        grid-row: 4 / 5;
    }

    .box-5 {
        grid-column: 1 / 4;
        grid-row: 5 / 6;
    }

    .box-6 {
        grid-column: 1 / 4;
        grid-row: 6 / 7;
    }

    .box-7 {
        grid-column: 1 / 4;
        grid-row: 7 / 8;
    }
}

